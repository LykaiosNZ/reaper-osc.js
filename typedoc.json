{
    "entryPoints": [
        "./src/index.ts"
    ],
    "out": "./docs",
    "exclude": [
        "**/*.d.ts",
        "**/Example.ts"
    ],
    "excludePrivate": true,
    "excludeExternals": true,
    "plugin": ["typedoc-github-theme"],
    "highlightLanguages": ["typescript", "javascript"],
    "sourceLinkTemplate": "https://github.com/LykaiosNZ/reaper-osc.js/blob/main/{path}#L{line}",
    "navigationLinks": {
        "Source": "https://github.com/LykaiosNZ/reaper-osc.js/"
    }
}
